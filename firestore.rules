rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) { 
      return id is string && id.size() >= 4 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function incoming() { 
      return request.resource.data; 
    }

    function existing() { 
      return resource.data; 
    }

    function isValidSyncProfile(data) {
      return data.keys().hasAll(['lastSyncTime', 'dailyState', 'history', 'settings'])
        && data.keys().size() == 4
        && data.lastSyncTime is int
        && data.dailyState is map
        && data.history is map
        && data.settings is map;
    }

    // Match block for sync_profiles
    match /sync_profiles/{syncKey} {
      allow get, create, update: if isValidId(syncKey);

      // No delete access from client
      allow delete: if false;
    }
  }
}
