{
  "name": "react-example",
  "private": true,
  "version": "1.0.0",
  "description": "Trading Assistant and Management System",
  "author": "Soheil Keshtkar <soheil.keshtkar@gmail.com>",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"const fs = require('fs'); ['dist', 'dist-electron', 'server.js'].forEach(d => fs.existsSync(d) && fs.rmSync(d, {recursive: true, force: true}))\"",
    "lint": "tsc --noEmit",
    "electron:dev": "electron electron-main.cjs",
    "electron:build": "npm run build && electron-builder --win --x64 --publish never"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.15.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "build": {
    "appId": "com.soheil.tradingassistant",
    "productName": "TradingAssistant",
    "publish": null,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "preload.cjs"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Trading Assistant"
    }
  }
}
